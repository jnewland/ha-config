#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
REQUIREMENTS_FILE="$REPO_ROOT/requirements.txt"

usage() {
	cat >&2 <<'EOF'
Usage: ./script/cibuild
EOF
}

in_ci() {
	[[ -n "${CI:-}" ]]
}

required_hass_version() {
	local version

	if [[ ! -f "$REQUIREMENTS_FILE" ]]; then
		echo "Expected $REQUIREMENTS_FILE" >&2
		exit 1
	fi

	version="$(grep -E '^[[:space:]]*homeassistant==' "$REQUIREMENTS_FILE" | head -n 1 | sed -E 's/^[[:space:]]*homeassistant==([^[:space:]#]+).*/\1/')"
	if [[ -z "$version" ]]; then
		echo "Expected pinned homeassistant==... in $REQUIREMENTS_FILE" >&2
		exit 1
	fi

	echo "$version"
}

load_env() {
	if [[ -f .env ]]; then
		set -a
		# shellcheck disable=SC1090
		source .env
		set +a
		echo "Loaded env vars from .env"
		return 0
	fi

	echo "Expected .env in $REPO_ROOT" >&2
	exit 1
}

run_hass() {
	if in_ci; then
		if command -v hass >/dev/null 2>&1; then
			hass "$@"
			return
		fi

		echo "Expected hass on PATH when CI is set." >&2
		exit 127
	fi

	if [[ -x "$REPO_ROOT/.venv/bin/hass" ]]; then
		"$REPO_ROOT/.venv/bin/hass" "$@"
		return
	fi

	if [[ -x "$REPO_ROOT/.venv/bin/python" ]]; then
		"$REPO_ROOT/.venv/bin/python" -m homeassistant "$@"
		return
	fi

	echo "Expected Home Assistant in $REPO_ROOT/.venv. Run ./script/bootstrap." >&2
	exit 127
}

installed_hass_version() {
	if [[ ! -x "$REPO_ROOT/.venv/bin/python" ]]; then
		return 1
	fi

	"$REPO_ROOT/.venv/bin/python" - <<'PY'
from importlib.metadata import PackageNotFoundError, version

try:
    print(version("homeassistant"))
except PackageNotFoundError:
    raise SystemExit(1)
PY
}

ensure_hass_version() {
	local expected_version
	local installed_version

	if in_ci; then
		return
	fi

	expected_version="$(required_hass_version)"
	if ! installed_version="$(installed_hass_version)"; then
		echo "Home Assistant is not installed in $REPO_ROOT/.venv. Run ./script/bootstrap." >&2
		exit 127
	fi

	if [[ "$installed_version" != "$expected_version" ]]; then
		echo "Home Assistant version mismatch: installed $installed_version, expected $expected_version from $REQUIREMENTS_FILE. Run ./script/bootstrap." >&2
		exit 1
	fi
}

make_temp_log() {
	local tmp_dir
	local log_file

	tmp_dir="${TMPDIR:-/tmp}"
	if [[ -d "$tmp_dir" ]]; then
		if log_file="$(mktemp "$tmp_dir/cibuild.XXXXXX.log" 2>/dev/null)"; then
			echo "$log_file"
			return 0
		fi
	fi

	if log_file="$(mktemp -t "cibuild.XXXXXX" 2>/dev/null)"; then
		echo "$log_file"
		return 0
	fi

	echo "Failed to create a temporary log file" >&2
	exit 1
}

run_check_config() {
	local log_file
	local error_count

	log_file="$(make_temp_log)"
	trap 'rm -f "$log_file"' EXIT

	touch automations.yaml
	run_hass -c . --script check_config -i all -f | tee "$log_file"

	error_count="$(grep -v "Unknown device" "$log_file" | grep -c '^ERROR' || true)"
	set -x
	test "$error_count" -eq 0
}

while [[ $# -gt 0 ]]; do
	case "$1" in
		-h|--help)
			usage
			exit 0
			;;
		*)
			echo "Unknown argument: $1" >&2
			usage
			exit 1
			;;
	esac
	shift
done

cd "$REPO_ROOT"

load_env
ensure_hass_version
run_check_config
